{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "headerText": "# Finova — Contexto completo para agente\n\nGenerado automáticamente con repomix.\nUsar como contexto inicial para Gema o Claude Opus en Antigravity.\nNo editar manualmente — re-generar con: npm run ctx\n",
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": true,
    "copyToClipboard": false
  },
  "include": [
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "backend/**/*.ts",
    "supabase/migrations/**/*.sql",
    "CLAUDE.md",
    "PLAN_TAREA.md",
    "package.json",
    "frontend/package.json"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "node_modules/**",
      "dist/**",
      ".env*",
      "repomix-output.md",
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/*.test.tsx",
      "apps/api/.env"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}
